# EstacionaPro — variables de entorno (copia este archivo a .env)
# NUNCA subas tu .env real al repositorio.

# Puerto HTTP del servidor
PORT=3000

# Ruta del archivo SQLite (se crea automáticamente)
DB_PATH=estacionapro.db

# Clave de operador/administrador.
# CÁMBIALA por un valor largo y aleatorio en producción.
ADMIN_TOKEN=cambia-esta-clave-en-produccion
